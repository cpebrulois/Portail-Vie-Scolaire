# ========================================================================
# .gitignore - Portail Vie Scolaire
# ========================================================================
# Remplace un .gitignore importé par erreur d'aethonyx_phenix_synth_v2,
# qui ignorait notamment index.html, src/ et DEPLOYMENT.md.
# ========================================================================

# === Système ===
*.pyc
__pycache__/
*.tmp
*.swp
.DS_Store
Thumbs.db

# === Modèles locaux ===
# local_llm.js charge son modèle depuis HuggingFace au runtime.
# Aucun poids ne doit être versionné ici (448 Mo purgés de l'historique).
models/
model/
*.gguf
*.onnx

# === Résidus de téléchargement ===
*.7z
*.img
*.ccd
*.sub
